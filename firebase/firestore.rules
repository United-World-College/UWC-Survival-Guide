rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in get(/databases/$(database)/documents/config/admins).data.emails;
    }

    // Anyone can read user profiles (for public author pages);
    // only the user themselves can write their own profile.
    match /users/{uid} {
      allow read;
      // First write (create) — author_id must be present and valid
      allow create: if request.auth != null && request.auth.uid == uid
        && 'author_id' in request.resource.data
        && request.resource.data.author_id is string
        && request.resource.data.author_id.size() > 0
        && request.resource.data.author_id.matches('^[a-z0-9]+(-[a-z0-9]+)*$');
      // Subsequent writes — author_id cannot be changed once set.
      // Legacy docs without author_id may backfill it once using the same slug rules.
      allow update: if request.auth != null && request.auth.uid == uid
        && (
          request.resource.data.author_id == resource.data.author_id ||
          (
            !('author_id' in resource.data)
            && 'author_id' in request.resource.data
            && request.resource.data.author_id is string
            && request.resource.data.author_id.size() > 0
            && request.resource.data.author_id.matches('^[a-z0-9]+(-[a-z0-9]+)*$')
          )
        );
    }

    // Submissions: all writes go through Cloud Functions (Admin SDK bypasses
    // rules), so no client-side create, update, or delete is needed.
    // Admins can read all submissions (for the review panel);
    // owners can read their own.
    match /submissions/{docId} {
      allow create: if false;

      // Approved submissions are publicly readable (for author pages);
      // non-approved submissions require authentication as owner, coauthor, or admin.
      allow read: if resource.data.status == 'approved'
        || (request.auth != null &&
            (resource.data.uid == request.auth.uid ||
             ('coauthorUids' in resource.data && request.auth.uid in resource.data.coauthorUids) ||
             isAdmin()));

      allow update: if false;
      allow delete: if false;
    }

    // Private workflow audit trail for editor/coauthor actions.
    // Only verified admins may read it; all writes go through Cloud Functions.
    match /submissionAudit/{docId} {
      allow read: if isAdmin();
    }

    // Only admins with verified emails can read the GitHub token config
    match /config/{docId} {
      allow read: if isAdmin();
    }
  }
}
